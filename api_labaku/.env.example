# ============================================================
# Labaku API - Environment Configuration
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# Application
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta

# Base path — set to empty string if deployed at domain root (e.g. api.yourdomain.com)
# Set to /api if deployed in a subfolder (e.g. ucs.mathlab.id/api)
APP_BASE_PATH=/api

# Database
DB_HOST=localhost
DB_NAME=labaku_db
DB_USER=labaku_user
DB_PASS=your_strong_password_here
DB_CHARSET=utf8mb4

# JWT
JWT_SECRET=your_long_random_secret_key_here_at_least_64_chars
JWT_EXPIRY=604800

# ============================================================
# SMTP — Email (PHPMailer)
# ============================================================
SMTP_HOST=mail.example.com
SMTP_USER=no-reply@example.com
SMTP_PASS=your_smtp_password_here
SMTP_PORT=587
MAIL_FROM_NAME=Metal.
